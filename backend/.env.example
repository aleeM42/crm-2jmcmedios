# ============================================
# CRM 2jmcMedios - Variables de Entorno (PLANTILLA)
# Copia este archivo como .env y ajusta tu usuario.
# ============================================

# --- Conexión a PostgreSQL ---
#
# OPCIÓN A: PostgreSQL instalado localmente (sin Docker)
#   alejandra -> postgresql://alejandra:alejandra_dev2024@localhost:5432/crm_2jmc
#   david     -> postgresql://david:david_dev2024@localhost:5432/crm_2jmc
#   maria     -> postgresql://maria:maria_dev2024@localhost:5432/crm_2jmc
#
# OPCIÓN B: Docker + PostgreSQL local instalado (usa puerto 5433 para Docker)
#   Agrega POSTGRES_PORT=5433 en este .env y cambia el puerto en DATABASE_URL
#   alejandra -> postgresql://alejandra:alejandra_dev2024@localhost:5433/crm_2jmc
#   david     -> postgresql://david:david_dev2024@localhost:5433/crm_2jmc
#
DATABASE_URL="postgresql://<TU_USUARIO>:<TU_CLAVE>@localhost:5432/crm_2jmc"

# --- Docker: contraseña root del contenedor ---
POSTGRES_ROOT_PASSWORD=crm2jmc_root_2024

# --- Docker: puerto externo de PostgreSQL ---
# Descomenta y cambia a 5433 si tienes PostgreSQL instalado localmente
# POSTGRES_PORT=5433

# --- Entorno ---
NODE_ENV=development
PORT=3001
