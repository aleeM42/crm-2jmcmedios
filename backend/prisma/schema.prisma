// ==============================================
// CRM 2jmcMedios - Prisma Schema
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- VENDEDOR ----
model Vendedor {
  id          Int      @id @default(autoincrement())
  nombre      String
  apellido    String
  email       String   @unique
  telefono    String?
  cargo       String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  clientes    Cliente[]
  visitas     Visita[]

  @@map("vendedores")
}

// ---- CLIENTE ----
model Cliente {
  id            Int      @id @default(autoincrement())
  razonSocial   String   @map("razon_social")
  ruc           String?  @unique
  direccion     String?
  ciudad        String?
  sector        String?
  tipoCliente   String?  @map("tipo_cliente")
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  vendedorId    Int?     @map("vendedor_id")
  vendedor      Vendedor? @relation(fields: [vendedorId], references: [id])

  contactos     Contacto[]
  visitas       Visita[]

  @@map("clientes")
}

// ---- CONTACTO ----
model Contacto {
  id          Int      @id @default(autoincrement())
  nombre      String
  apellido    String
  email       String?
  telefono    String?
  cargo       String?
  esPrincipal Boolean  @default(false) @map("es_principal")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  clienteId   Int      @map("cliente_id")
  cliente     Cliente  @relation(fields: [clienteId], references: [id])

  @@map("contactos")
}

// ---- VISITA ----
model Visita {
  id            Int      @id @default(autoincrement())
  fecha         DateTime
  motivo        String
  observaciones String?
  estado        String   @default("programada")
  resultado     String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  clienteId     Int      @map("cliente_id")
  cliente       Cliente  @relation(fields: [clienteId], references: [id])

  vendedorId    Int      @map("vendedor_id")
  vendedor      Vendedor @relation(fields: [vendedorId], references: [id])

  @@map("visitas")
}
